{
  "id": "report-formater",
  "name": "Report Formatter",
  "description": "Consolidate multi-source scientific documents into clean, print-to-PDF HTML reports",
  "version": "1.0.0",
  "author": "Patrick Munier",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/patrick-mun/report_skill"
  },
  "homepage": "https://github.com/patrick-mun/report_skill",
  "triggers": ["/report"],
  "path": "./",
  "commands": {
    "report": {
      "description": "Consolidate and format project documents into professional reports",
      "usage": "/report [files...] [--audience AUDIENCE] [--mode MODE] [--language LANG]",
      "arguments": [
        {
          "name": "files",
          "type": "string[]",
          "optional": true,
          "description": "Source files (slides.json, budget.html, doc.md, etc.)"
        }
      ],
      "options": [
        {
          "name": "--audience",
          "type": "string",
          "values": ["funder", "scientist", "clinician", "institution", "public"],
          "description": "Generate one version per audience (comma-separated for multiple)"
        },
        {
          "name": "--mode",
          "type": "string",
          "values": ["layered"],
          "default": "layered",
          "description": "Single navigable document with executive summary → detail → annexes"
        },
        {
          "name": "--language",
          "type": "string",
          "values": ["EN", "FR"],
          "default": "EN",
          "description": "Output language"
        }
      ]
    }
  }
}
